# ============================================================
# E-Book Generator — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================


# ------------------------------------------------------------
# Supabase — https://supabase.com/dashboard
# Create a project → Settings → API
# ------------------------------------------------------------

# Your project's public URL (safe to expose to the browser)
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your project's anon/public key (safe to expose to the browser)
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here


# ------------------------------------------------------------
# Anthropic Claude — https://console.anthropic.com/keys
# Used for: chapter drafting, outlining, self-correction passes
# Model used: claude-3-5-sonnet-20241022 (default) / claude-3-opus-20240229
# ------------------------------------------------------------
# NOTE: This app passes the key from the Settings UI at runtime.
# You can optionally pre-seed it here for server-side default use.
ANTHROPIC_API_KEY=sk-ant-...


# ------------------------------------------------------------
# Exa AI — https://dashboard.exa.ai/api-keys
# Used for: semantic neural web search / grounding research
# ------------------------------------------------------------
EXA_API_KEY=exa-...


# ------------------------------------------------------------
# Image Generation Provider (choose one)
#
# Option A — Kie.ai:   https://kie.ai/dashboard (API keys section)
# Option B — 69labs:   https://69labs.vip       (account → API)
#
# Used for: book cover art and chapter illustrations
# ------------------------------------------------------------
IMAGE_API_KEY=your-image-api-key-here

# Set to "kie" or "69labs"
IMAGE_PROVIDER=kie
