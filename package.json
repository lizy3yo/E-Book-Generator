		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@lucide/svelte": "^1.24.0",
		"@supabase/supabase-js": "^2.110.2",
		"html2canvas": "1.4.1",
		"html2pdf.js": "^0.14.0",
		"jspdf": "4.2.1",
		"tslib": "2.8.1"
